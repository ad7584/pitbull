# Copy to .env and fill in. Only VITE_-prefixed vars reach the browser.
# .env is gitignored; this template is committed.

# Privy app ID — public client key from dashboard.privy.io. Safe to expose.
VITE_PRIVY_APP_ID=your-privy-app-id

# Solana RPC endpoint (Helius / Triton / QuickNode).
# WARNING: VITE_ vars ship inside the browser bundle. Use a DOMAIN-RESTRICTED
# key (allowlist your domains in the provider dashboard), or proxy via a backend.
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key

# $ANSEM SPL mint (pinned). Optional — code falls back to this value.
VITE_ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump

# Custodial backend (Railway). Falls back to http://localhost:8787 for local dev.
VITE_API_URL=https://pitbull-server-production.up.railway.app
