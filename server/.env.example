# DEVNET by default. Do NOT point at mainnet-beta without an audit, legal
# review, and real key custody (KMS/HSM/multisig) — see README.
PITBULL_CLUSTER=devnet
# Optional custom RPC (else public devnet endpoint).
PITBULL_RPC_URL=
PORT=8787
# Privy app id (public) — verifies withdrawal auth tokens (owner-only).
PRIVY_APP_ID=
# DEVNET ONLY: allow withdrawals with no token (testing). NEVER set on mainnet.
# (The server refuses to boot if this is true while the RPC points at mainnet.)
ALLOW_INSECURE_WITHDRAW=false
# CORS allowlist (comma-separated origins). REQUIRED on mainnet (fail-closed);
# blank on devnet reflects all origins. e.g. https://app.pitbull.fun
CORS_ORIGINS=
# Mainnet RPC for the LP engine (the $ANSEM pool is mainnet-only; read-only
# until LP goes live). Use a domain-restricted provider key.
LP_MAINNET_RPC_URL=
# LP live execution — leave UNSET/false. Enabling moves real funds; only after
# audit + staged rollout. The engine simulates by default.
LP_LIVE_ENABLED=false
# DATABASE_URL and the keeper/master-seed secrets are set separately (never commit).
